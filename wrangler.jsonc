{
  // Cloudflare Pages + D1 config.
  // Docs: https://developers.cloudflare.com/pages/functions/wrangler-configuration/
  "name": "songbubble",

  // Serve the static site from the repo root (no build step).
  "pages_build_output_dir": ".",

  "d1_databases": [
    {
      // The binding name used in Functions: env.DB
      "binding": "DB",
      "database_name": "songbubble-db",
      "database_id": "6727e8a5-16e8-4365-b26c-062894c58c03",
      "migrations_dir": "migrations"
    }
  ]
}
